fn fib(n: int) -> int:
    if n <= 1:
        return n
    return fib(n - 1) + fib(n - 2)

fn main() -> int:
    int x = 10
    x = x + 5

    array p[3] = [1, 2]
    p[2] = 9

    map m = {"a": 1}
    m["b"] = p[2]

    int i = 0
    int sum = 0
    while i < len(p):
        if i == 1:
            i = i + 1
            continue
        sum = sum + p[i]
        if sum > 20:
            break
        i = i + 1

    int f = fib(6)

    print(x)
    print(sum)
    print(f)
    print(m["b"])
    print((x > 10) and not false)
    return 0
