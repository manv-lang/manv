# ManV Standard Library Bootstrap Surface
#
# Why this file exists:
# - It is the compiler-shipped std entrypoint written in ManV source.
# - It defines thin, typed wrappers over narrowly scoped runtime intrinsics.
# - It is the bootstrap seam used while richer pure-ManV std modules are phased in.
#
# Policy notes:
# - Keep wrappers narrow and capability-oriented.
# - Do not place subsystem logic (JSON/HTTP/regex parsing, etc.) into intrinsics.
# - Prefer moving logic into ManV code as soon as bootstrap blockers are removed.

# Core builtins bridge.
fn core_len(x) -> int:
    return __intrin.core_len(x)

fn core_repr(x) -> str:
    return __intrin.core_repr(x)

fn core_hash(x) -> int:
    return __intrin.core_hash(x)

fn core_min(items: array):
    return __intrin.core_min(items)

fn core_max(items: array):
    return __intrin.core_max(items)

fn core_sum(items: array):
    return __intrin.core_sum(items)

fn core_any(items: array) -> bool:
    return __intrin.core_any(items)

fn core_all(items: array) -> bool:
    return __intrin.core_all(items)

fn core_sorted(items: array) -> array:
    return __intrin.core_sorted(items)

fn core_range(stop: int) -> array:
    return __intrin.core_range(stop)

fn core_enumerate(items: array) -> array:
    return __intrin.core_enumerate(items)

fn core_zip(items: array) -> array:
    return __intrin.core_zip(items)

fn core_int(x) -> int:
    return __intrin.core_int(x)

fn core_float(x) -> float:
    return __intrin.core_float(x)

fn core_bool(x) -> bool:
    return __intrin.core_bool(x)

fn core_str(x) -> str:
    return __intrin.core_str(x)

fn core_iter(x):
    return __intrin.core_iter(x)

fn core_next(it):
    return __intrin.core_next(it)

# IO bridge.
fn io_print(parts):
    return __intrin.io_print(parts)

fn io_read_line() -> str:
    return __intrin.io_read_line()

# Filesystem bridge.
fn fs_exists(path: str) -> bool:
    return __intrin.fs_exists(path)

fn fs_read_text(path: str) -> str:
    return __intrin.fs_read_text(path)

fn fs_write_text(path: str, data: str):
    return __intrin.fs_write_text(path, data)

fn fs_mkdir(path: str, recursive: bool):
    return __intrin.fs_mkdir(path, recursive)

fn fs_list(path: str) -> array:
    return __intrin.fs_list(path)

fn fs_remove(path: str):
    return __intrin.fs_remove(path)

# Path bridge.
fn path_join(parts: array) -> str:
    return __intrin.path_join(parts)

fn path_basename(path: str) -> str:
    return __intrin.path_basename(path)

fn path_dirname(path: str) -> str:
    return __intrin.path_dirname(path)

fn path_normalize(path: str) -> str:
    return __intrin.path_normalize(path)

fn path_is_abs(path: str) -> bool:
    return __intrin.path_is_abs(path)

# Time / Random bridge.
fn time_now_ms() -> int:
    return __intrin.time_now_ms()

fn time_monotonic_ms() -> int:
    return __intrin.time_monotonic_ms()

fn time_sleep_ms(ms: int):
    return __intrin.time_sleep_ms(ms)

fn rand_seed(seed: int):
    return __intrin.rand_seed(seed)

fn rand_int(lo: int, hi: int) -> int:
    return __intrin.rand_int(lo, hi)

fn rand_float() -> float:
    return __intrin.rand_float()

# JSON bridge (bootstrap; target is pure-ManV parser/encoder).
fn json_parse(text: str) -> map:
    return __intrin.json_parse(text)

fn json_stringify(value) -> str:
    return __intrin.json_stringify(value)

# System / OS / Process / URL / HTTP bridge.
fn sys_capabilities() -> map:
    return __intrin.sys_capabilities()

fn sys_require(name: str):
    return __intrin.sys_require(name)

fn os_getenv(name: str) -> str:
    return __intrin.os_getenv(name)

fn os_setenv(name: str, value: str):
    return __intrin.os_setenv(name, value)

fn os_getcwd() -> str:
    return __intrin.os_getcwd()

fn os_chdir(path: str):
    return __intrin.os_chdir(path)

fn process_run(argv: array) -> map:
    return __intrin.process_run(argv)

fn url_parse(url: str) -> map:
    return __intrin.url_parse(url)

fn http_request(method: str, url: str, body: str, headers: map) -> map:
    return __intrin.http_request(method, url, body, headers)

fn std_syscall(target, args: array) -> map:
    return __intrin.syscall_invoke(target, args)

fn std_syscall_posix(number: int, args: array) -> map:
    return __intrin.syscall_invoke(number, args)

fn std_syscall_windows(name: str, args: array) -> map:
    return __intrin.syscall_invoke(name, args)

# Memory and GC controls.
fn mem_collect():
    return __intrin.mem_collect()

fn mem_stats() -> map:
    return __intrin.mem_stats()

fn mem_set_deterministic_gc(flag: bool):
    return __intrin.mem_set_deterministic_gc(flag)

fn mem_set_gc_stress(flag: bool):
    return __intrin.mem_set_gc_stress(flag)

# GPU bridge for backend dispatch and capability probing.
fn gpu_backends() -> array:
    return __intrin.gpu_backends()

fn gpu_capabilities() -> map:
    return __intrin.gpu_capabilities()

fn gpu_dispatch(kernel: map, backend: str, target: str, inputs: map, launch: map) -> map:
    return __intrin.gpu_dispatch(kernel, backend, target, inputs, launch)

fn main() -> int:
    print("std ready")

    let caps = sys_capabilities()
    print(core_len(caps))
    print(core_len(gpu_backends()))

    return 0
    